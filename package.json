{
  "name": "schalkneethling.com",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "setup:playwright": "pnpm exec playwright install chromium",
    "build": "pnpm run generate:og && astro build",
    "generate:og": "node scripts/generate-og-cards.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check",
    "test:a11y": "playwright test",
    "a11y:viewer": "axe-aggregate-viewer ./full-report.json",
    "a11y:viewer:standalone": "axe-aggregate-viewer ./full-report.json --standalone",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^5.0.6",
    "@astrojs/rss": "^4.0.18",
    "@schalkneethling/masonry-gridlanes-wc": "^0.1.0",
    "astro": "^6.4.4",
    "astro-embed": "^0.13.0",
    "typescript": "^6.0.3",
    "varlock": "^1.4.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@schalkneethling/axe-aggregate-reporter": "0.6.2",
    "@schalkneethling/opengraph-cards-maker": "^0.3.0",
    "@varlock/1password-plugin": "^1.1.0",
    "axe-core": "^4.12.0",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@11.0.9"
}
